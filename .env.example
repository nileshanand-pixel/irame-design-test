# Environment Configuration Example
# Copy this file to .env and fill in the appropriate values for your environment

VITE_ENV="your_environment"
VITE_STAGE_BASE_URL="https://your-api-url.com"
VITE_GOOGLE_AUTH_API_URL="https://your-auth-url.com"
VITE_GATEKEEPER_BASE_URL="https://your-gatekeeper-url.com"
VITE_STAGE_APP_TOKEN="your_app_token"

# Auth & Security
VITE_COGNITO_CLIENT_ID="your_cognito_client_id"
VITE_DISABLE_REACT_STRICT_MODE=true
VITE_ENABLE_RBAC=false
VITE_DEBUG_MODE=false

# Mixpanel Settings
VITE_MIXPANEL_DISABLED=true
VITE_MIXPANEL_URL="https://your-mixpanel-url.com"
VITE_MIXPANEL_TOKEN="your_mixpanel_token"

# Sentry / Error Tracking
VITE_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project_id"
VITE_SENTRY_TUNNEL="https://your-sentry-tunnel.com"

# Feature Flags
VITE_ENABLE_BULK_INPUT_MODE=true

# External Services
VITE_GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/your_script_id/exec"
VITE_WIDGET_ID="your_widget_id"
VITE_TASK_SERVICE_URL="https://your-task-service.com"

# PDF Configuration
VITE_USE_PDFIO_FOR_REPORTS=true
VITE_PDFIO_SERVICE_URL="http://localhost:4000"
VITE_PDF_SERVER_ENDPOINT="https://your-pdf-server.com"
VITE_PDF_SIZE_LIMIT_ENABLED=false
VITE_UNSTRUCTURED_IMAGES_ENABLED=true
VITE_PDF_MAX_TOTAL_SIZE_MB=100

# Recaptcha
VITE_IS_RECAPTCHA_ENABLED=false
VITE_RECAPTCHA_SITE_KEY="your_recaptcha_site_key"


# Freshdesk
VITE_WIDGET_ID="your_freshdesk_widget_id"